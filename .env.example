# Solana Configuration
# Network: 'mainnet-beta', 'testnet', 'devnet', or 'localnet'
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Solana RPC endpoint URL
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Lacus program ID (deployed on Solana devnet)
NEXT_PUBLIC_LACUS_PROGRAM_ID=Fnw9tWvwyMXieH35WhFfDz7behbDo1teBrVJZ4pZq7rL

# USDC mint address (custom devnet USDC with mint authority)
NEXT_PUBLIC_USDC_MINT=4tKWXwLpNX5hxJeKceHBG3KJBv43RmGU3rQW3e35r4nR

# Faucet Configuration (server-side only)
# Base58-encoded private key of the mint authority for test USDC
FAUCET_KEYPAIR_SECRET=PASTE_MINT_AUTHORITY_BASE58_HERE

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# WalletConnect Project ID (for wallet adapter)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
